# Sunucu portu (Render/Koyeb otomatik ayarlar, lokal icin 3000)
PORT=3000

# Frontend kaynagi (CORS icin). Birden fazla icin virgulle ayirin.
# Ornek: https://kullaniciadi.github.io,https://example.com
# Tum kaynaklar icin: *
ALLOWED_ORIGINS=*

# WhatsApp Grup ID'si - Format: 1234567890-1234567890@g.us
# Grup ID'sini ogrenmek icin sunucuyu baslatip /api/groups endpoint'ini kullanin.
WHATSAPP_GROUP_ID=

# Anti-spam: ayni masadan ardisik istekler arasi minimum saniye
COOLDOWN_SECONDS=60

# Baileys auth bilgilerinin saklanacagi klasor (kalici disk yolu)
# Render'da Persistent Disk mount path'i ile eslestirilmeli (orn: /var/data/auth_info)
AUTH_DIR=./auth_info

# Saat dilimi (mesaj formati icin)
TZ=Europe/Istanbul

# GPS Konum Ayarlari (Merkez koordinatlari ve izin verilen sapma metre cinsi)
TARGET_LAT=41.2505
TARGET_LNG=29.0205
ALLOWED_RADIUS_METERS=250
