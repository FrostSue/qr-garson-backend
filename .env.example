# Server port
PORT=3000

# Frontend origins for CORS (comma-separated, or * for all)
ALLOWED_ORIGINS=*

# WhatsApp Group JID (e.g. 1234567890-1234567890@g.us)
WHATSAPP_GROUP_ID=

# Anti-spam cooldown in seconds per table
COOLDOWN_SECONDS=60

# Persistent directory for Baileys auth session files
AUTH_DIR=./auth_info

# Server timezone
TZ=Europe/Istanbul

# GPS Geofencing Settings (Target coordinates and allowed radius in meters)
TARGET_LAT=40.171667
TARGET_LNG=38.062306
ALLOWED_RADIUS_METERS=400
